# Variables de entorno requeridas para todo-backend
# Copia este archivo como .env y rellena los valores reales
# NUNCA commitees el archivo .env — está en .gitignore

# ── Supabase ────────────────────────────────────────────────────────────────
# URL del proyecto Supabase (Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Clave anónima — segura para exponer (protegida por RLS)
# (Project Settings → API → Project API keys → anon public)
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Clave de servicio — NUNCA exponer al cliente
# Solo se usa en el backend para verificar tokens JWT
# (Project Settings → API → Project API keys → service_role)
SUPABASE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# JWT Secret del proyecto Supabase
# (Project Settings → API → JWT Settings → JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret-base64-encoded

# ── Entorno ──────────────────────────────────────────────────────────────────
# Valores: "production" | "development"
# En producción: deshabilita /docs, /redoc, /openapi.json
#                CORS solo permite el dominio de Vercel
ENVIRONMENT=development
